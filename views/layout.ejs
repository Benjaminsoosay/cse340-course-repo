<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Service Network</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/">CSE 340</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <% if (user) { %>
          <li class="nav-item"><a class="nav-link" href="/organizations">Organizations</a></li>
          <li class="nav-item"><a class="nav-link" href="/projects">Projects</a></li>
          <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
          <% if (isAdmin) { %>
            <li class="nav-item"><a class="nav-link text-warning" href="/organizations/create">+ Org</a></li>
            <li class="nav-item"><a class="nav-link text-warning" href="/projects/create">+ Project</a></li>
            <li class="nav-item"><a class="nav-link text-warning" href="/categories/create">+ Category</a></li>
          <% } %>
          <li class="nav-item"><a class="nav-link" href="/logout">Logout (<%= user.name || user.username %>)</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
          <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<div class="container mt-4">
  <% if (flash && typeof flash === 'function') {
       const messages = flash();
       if (messages.success && messages.success.length) { %>
         <div class="alert alert-success"><%= messages.success.join('<br>') %></div>
  <% } if (messages.error && messages.error.length) { %>
         <div class="alert alert-danger"><%= messages.error.join('<br>') %></div>
  <% } } else {
       if (messages && messages.success) { %>
         <div class="alert alert-success"><%= messages.success %></div>
  <% } if (messages && messages.error) { %>
         <div class="alert alert-danger"><%= messages.error %></div>
  <% } } %>
  <%- body %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
