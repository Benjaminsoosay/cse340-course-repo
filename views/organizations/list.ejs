<h1>Organizations</h1>
<% if (isAdmin) { %>
  <a href="/organizations/create" class="btn btn-primary mb-3">+ New Organization</a>
<% } %>
<table class="table table-striped">
  <thead>
    <tr><th>Name</th><th>Description</th><th>Actions</th></tr>
  </thead>
  <tbody>
    <% organizations.forEach(org => { %>
      <tr>
        <td><%= org.name %></td>
        <td><%= org.description || '' %></td>
        <td>
          <a href="/organizations/<%= org.organization_id %>" class="btn btn-sm btn-info">View</a>
          <% if (isAdmin) { %>
            <a href="/organizations/edit/<%= org.organization_id %>" class="btn btn-sm btn-warning">Edit</a>
          <% } %>
         </td>
       </tr>
    <% }) %>
  </tbody>
</table>
