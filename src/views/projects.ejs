<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CSE 340</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <h1><%= title %></h1>
        <% if (projects && projects.length > 0) { %>
            <ul class="projects-list">
                <% projects.forEach(project => { %>
                    <li>
                        <h3>
                            <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                        </h3>
                        <p><%= project.description %></p>
                        <p><strong>Date:</strong> <%= project.date.toDateString ? project.date.toDateString() : project.date %></p>
                        <p><strong>Location:</strong> <%= project.location %></p>
                        <p><strong>Organization:</strong> 
                            <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                        </p>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>No upcoming service projects at this time.</p>
        <% } %>

        <!-- Link to add a new service project -->
        <p><a href="/new-project">Add a New Service Project</a></p>
    </main>

    <%- include('partials/footer') %>
</body>
</html>