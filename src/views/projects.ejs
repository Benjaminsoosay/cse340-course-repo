<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CSE 340</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <h1><%= title %></h1>

        <% if (projects && projects.length > 0) { %>
            <div class="projects-list">
                <% projects.forEach(project => { %>
                    <div class="project-card">
                        <h2><%= project.name %></h2>
                        <p><%= project.description %></p>
                        <p><strong>Organization:</strong> <%= project.organization_name %></p>
                        <p><strong>Date:</strong> <%= new Date(project.start_date).toLocaleDateString() %></p>
                        <p><strong>Location:</strong> <%= project.location %></p>

                        <!-- ✅ Volunteer form – only show if project.id exists -->
                        <% if (project && project.id) { %>
                            <form action="/projects/<%= project.id %>/volunteer" method="POST">
                                <button type="submit" class="btn btn-primary">Volunteer for this project</button>
                            </form>
                        <% } else { %>
                            <!-- fallback: show a link to the project detail page -->
                            <a href="/project/<%= project.id %>">View details to volunteer</a>
                        <% } %>

                        <p><a href="/project/<%= project.id %>">More details →</a></p>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p>No upcoming projects at this time.</p>
        <% } %>
    </main>

    <%- include('partials/footer') %>
</body>
</html>