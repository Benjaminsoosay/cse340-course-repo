<%- include('partials/header') %>

<main>
    <h1><%= project.name %></h1>
    
    <section class="project-info">
        <p>
            <strong>Date:</strong> 
            <%= new Date(project.date).toLocaleDateString('en-US', { 
                month: 'long', 
                day: 'numeric', 
                year: 'numeric' 
            }) %>
        </p>
        
        <p><strong>Location:</strong> <%= project.location %></p>
        
        <p>
            <strong>Partner Organization:</strong> 
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <hr>

        <h3>Description</h3>
        <p><%= project.description %></p>
        
        <div class="project-tags">
            <h3>Categories:</h3>
            <div class="tags-container">
                <% if (assignedCategories && assignedCategories.length > 0) { %>
                    <% assignedCategories.forEach(cat => { %>
                        <a href="/category/<%= cat.id %>" class="tag">
                            <%= cat.name %>
                        </a>
                    <% }); %>
                <% } else { %>
                    <p>No categories assigned.</p>
                <% } %>
            </div>
        </div>
    </section>
    
    <!-- Volunteer Section -->
    <% if (user) { %>
        <section class="volunteer-section">
            <% if (!userIsVolunteer) { %>
                <form action="/projects/<%= project.id %>/volunteer" method="POST">
                    <button type="submit" class="btn btn-primary">Volunteer for this Project</button>
                </form>
            <% } else { %>
                <form action="/projects/<%= project.id %>/remove-volunteer" method="POST">
                    <button type="submit" class="btn btn-outline-danger">Remove Me as Volunteer</button>
                </form>
            <% } %>
        </section>
    <% } else { %>
        <p><a href="/login">Log in</a> to volunteer for this project.</p>
    <% } %>

    <section class="buttons">
        <% if (user && user.role_name === 'admin') { %>
            <button>
                <a href="/assign-categories/<%= project.id %>">Edit Categories</a>
            </button>
            <button>
                <a href="/edit-project/<%= project.id %>">Edit Project</a>
            </button>
        <% } %>
        <button>
            <a href="/projects">← Back to Upcoming Projects</a>
        </button>
    </section>
</main>

<%- include('partials/footer') %>