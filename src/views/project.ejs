<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= project.name %> | CSE 340</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <h1><%= project.name %></h1>

        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Date:</strong> <%= new Date(project.start_date).toLocaleDateString() %></p>
        <p><strong>Description:</strong> <%= project.description %></p>

        <!-- Volunteer section -->
        <% if (user) { %>
            <div class="volunteer-section">
                <% if (userIsVolunteer) { %>
                    <p class="volunteer-status">You are volunteering for this project.</p>
                    <form action="/projects/<%= project.id %>/remove-volunteer" method="POST">
                        <button type="submit" class="btn btn-danger">Remove me as volunteer</button>
                    </form>
                <% } else { %>
                    <form action="/projects/<%= project.id %>/volunteer" method="POST">
                        <button type="submit" class="btn btn-primary">Volunteer for this project</button>
                    </form>
                <% } %>
            </div>
        <% } else { %>
            <p><a href="/login">Log in</a> to volunteer for this project.</p>
        <% } %>

        <p><a href="/projects">← Back to all projects</a></p>
    </main>

    <%- include('partials/footer') %>
</body>
</html>