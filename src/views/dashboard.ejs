<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p><strong>Name:</strong> <%= name %></p>
    <p><strong>Email:</strong> <%= email %></p>
    <p><strong>Role:</strong> <%= role %></p>

    <!-- NEW: Volunteered Projects Section -->
    <h2>Projects You Are Volunteering For</h2>

    <% if (volunteeredProjects && volunteeredProjects.length > 0) { %>
        <div class="volunteer-list">
            <% volunteeredProjects.forEach(project => { %>
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title"><%= project.name %></h5>
                        <p class="card-text"><%= project.description %></p>
                        <p><strong>Organization:</strong> <%= project.organization_name %></p>
                        <p><strong>Dates:</strong> <%= project.start_date %> to <%= project.end_date %></p>
                        <form action="/projects/<%= project.id %>/volunteer/remove" method="POST">
                            <button type="submit" class="btn btn-danger btn-sm">Remove Volunteering</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p>You haven't volunteered for any projects yet. <a href="/projects">Browse projects</a> to get started.</p>
    <% } %>

    <% if (isAdmin) { %>
        <h2>Admin Panel</h2>
        <ul>
            <li><a href="/new-organization">Create New Organization</a></li>
            <li><a href="/new-project">Create New Project</a></li>
            <li><a href="/new-category">Create New Category</a></li>
            <li><a href="/admin/users">Manage Users</a></li>
        </ul>
    <% } %>
</main>

<%- include('partials/footer') %>