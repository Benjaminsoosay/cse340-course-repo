<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p><strong>Name:</strong> <%= user.name %></p>
    <p><strong>Email:</strong> <%= user.email %></p>
    <p><strong>Role:</strong> <%= user.role %></p>

    <h2>Projects You Are Volunteering For</h2>

    <% if (volunteeringProjects && volunteeringProjects.length > 0) { %>
        <div class="projects-list">
            <% volunteeringProjects.forEach(project => { %>
                <div class="project-card">
                    <h3><%= project.name %></h3>
                    <p><%= project.description %></p>
                    <p><strong>Organization:</strong> <%= project.organization_name %></p>
                    <p><strong>Date:</strong> 
                        <%= project.start_date ? new Date(project.start_date).toLocaleDateString() : 'TBD' %>
                    </p>
                    <!-- If you have end_date, add it similarly -->
                    <form action="/projects/<%= project.id %>/remove-volunteer" method="POST">
                        <button type="submit" class="btn btn-danger">Remove Volunteering</button>
                    </form>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <p>You haven't volunteered for any projects yet. <a href="/projects">Browse projects</a> to get started.</p>
    <% } %>

    <% if (isAdmin) { %>
        <h2>Admin Panel</h2>
        <ul>
            <li><a href="/new-organization">Create New Organization</a></li>
            <li><a href="/new-project">Create New Project</a></li>
            <li><a href="/new-category">Create New Category</a></li>
            <li><a href="/admin/users">Manage Users</a></li>
        </ul>
    <% } %>
</main>

<%- include('partials/footer') %>