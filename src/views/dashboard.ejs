<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <!-- User Information -->
    <section class="user-info">
        <h2>Your Profile</h2>
        <p><strong>Name:</strong> <%= user.name %></p>
        <p><strong>Email:</strong> <%= user.email %></p>
        <p><strong>Account Level:</strong> <%= user.role_name || user.role %></p>
    </section>

    <!-- Volunteering Projects -->
    <section class="volunteering-projects">
        <h2>Projects You Are Volunteering For</h2>

        <% if (volunteeringProjects && volunteeringProjects.length > 0) { %>
            <div class="projects-list">
                <% volunteeringProjects.forEach(project => { %>
                    <div class="project-card">
                        <h3><%= project.name || project.title %></h3>
                        <p><%= project.description %></p>
                        <p><strong>Organization:</strong> <%= project.organization_name %></p>
                        <p><strong>Date:</strong>
                            <%= project.start_date ?
                                new Date(project.start_date).toLocaleDateString() :
                                (project.date ? new Date(project.date).toLocaleDateString() : 'TBD')
                            %>
                        </p>
                        <form action="/projects/<%= project.id || project.project_id %>/remove-volunteer" method="POST">
                            <button type="submit" class="btn btn-danger">Remove Volunteering</button>
                        </form>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p>You haven't volunteered for any projects yet.
                <a href="/projects">Browse projects</a> to get started.</p>
        <% } %>
    </section>

    <!-- Admin Controls (visible only to admin users) -->
    <% if (user && user.role === 'admin') { %>
        <hr>
        <h3>Admin Controls</h3>
        <ul>
            <li><a href="/organizations/create">Create Organization</a></li>
            <li><a href="/projects/create">Create Project</a></li>
            <li><a href="/categories/create">Create Category</a></li>
            <li><a href="/users">Manage Users</a></li>
        </ul>
    <% } %>

    <!-- Logout Button -->
    <hr>
    <div class="logout-container">
        <a href="/logout" class="btn btn-primary">Logout</a>
    </div>
</main>

<%- include('partials/footer') %>