<%- include('partials/header') %>

<main class="category-page">
    <div class="container">
        <h1><%= title %></h1>

        <div class="categories-grid">
            <% if (categories && categories.length > 0) { %>
                <% categories.forEach(category => { %>
                    <div class="category-card">
                        <h2><%= category.name %></h2>
                        <a href="/category/<%= category.id %>" class="btn btn-outline">View Projects →</a>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="no-results">No categories found.</p>
            <% } %>
        </div>

        <!-- Admin‑only button to add a new category -->
        <% if (user && user.role_name === 'admin') { %>
            <div class="admin-actions">
                <a href="/new-category" class="btn btn-primary">+ Add New Category</a>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>